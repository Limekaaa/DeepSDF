{
  "Description" : "This experiment learns a shape representation for unit squares with holes.",
  "DataSource" : "examples/data/",
  "TrainSplit" : "train_data",
  "TestSplit" : "test_data",
  "NetworkArch" : "deep_sdf_decoder",
  "NetworkSpecs" : {
    "dims" : [ 128, 128, 128],
    "dropout" : [0, 1, 2],
    "dropout_prob" : 0.2,
    "norm_layers" : [0, 1, 2],
    "latent_in" : [1],
    "xyz_in_all" : false,
    "use_tanh" : true,
    "latent_dropout" : false,
    "weight_norm" : true
    },
  "CodeLength" : 64,
  "NumEpochs" : 2001,
  "SnapshotFrequency" : 500,
  "AdditionalSnapshots" : [ 50, 100 ],
  "LearningRateSchedule" : [
    {
      "Type" : "Step",
      "Initial" : 0.0005,
      "Interval" : 500,
      "Factor" : 0.5
    },
    {
      "Type" : "Step",
      "Initial" : 0.001,
      "Interval" : 500,
      "Factor" : 0.5
    }],
  "SamplesPerScene" : 10201,
  "ScenesPerBatch" : 64,
  "DataLoaderThreads" : 16,
  "ClampingDistance" : 0.1,
